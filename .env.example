POSTGRES_DB=your_db_name
POSTGRES_PASSWORD=your_db_password
POSTGRES_USER=your_db_user

# keycloak
KEYCLOAK_ADMIN=your_keycloak_admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_password
# 회원가입용 (관리자 권한)
KEYCLOAK_ADMIN_SECRET=your_keycloak_admin_secret
# 로그인용 (일반 클라이언트 권한)
KEYCLOAK_USER_SECRET=your_keycloak_user_secret

# notification-service에서 사용 (AI 발송 시한 계산)
# 필수: Gemini API 키 발급 후 입력
GEMINI_API_KEY=your_gemini_api_key
# 필수: Slack Bot Token 발급 후 입력
SLACK_TOKEN=your_slack_token

# company-service
COMPANY_SERVICE_PORT=19300
COMPANY_SERVICE_NAME=company-service
COMPANY_SERVICE_SCHEMA=company_schema

# product-service
PRODUCT_SERVICE_PORT=19400
PRODUCT_SERVICE_NAME=product-service
PRODUCT_SERVICE_SCHEMA=product_schema

# HUB
HUB_SERVICE_NAME=hub-service
HUB_SERVICE_PORT=19200
HUB_SERVICE_SCHEMA=hub_schema

# api-gateway
GATEWAY_NAME=api-gateway
GATEWAY_PORT=19000

# order-service
ORDER_SERVICE_NAME=order-service
ORDER_SERVICE_PORT=19500
ORDER_SERVICE_SCHEMA=order_schema

# notification
NOTIFICATION_SERVICE_NAME=notification-service
NOTIFICATION_SERVICE_PORT=19700
NOTIFICATION_SERVICE_SCHEMA=notification_schema

# TMAP
TMAP_API_KEY=tmap-api-key

# user-service
USER_SERVICE_NAME=user-service
USER_SERVICE_PORT=19100
USER_SERVICE_SCHEMA=user_schema

